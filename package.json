{
  "name": "agentlens",
  "version": "0.1.0",
  "description": "See what your AI coding agents store on your machine. Scan memory files, token costs, feature flags, session transcripts, and data footprint.",
  "type": "module",
  "bin": {
    "agentlens": "./bin/agentlens.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "observability",
    "transparency",
    "cost-tracking",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "author": "katlaszlo",
  "repository": {
    "type": "git",
    "url": "https://github.com/katrinalaszlo/agentlens.git"
  },
  "homepage": "https://github.com/katrinalaszlo/agentlens#readme",
